{
  "name": "codecatalyst-backend",
  "version": "1.0.0",
  "description": "CodeCatalyst LMS REST API (Express + MySQL)",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "start:win": "node src/index.js",
    "test": "node src/tests/payment-admin.test.js",
    "setup": "echo 'Installing backend dependencies...' && npm install",
    "setup:clean": "echo 'Clean setup for backend...' && rm -rf node_modules package-lock.json && npm install && npm run dev"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}

